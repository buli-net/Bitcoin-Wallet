<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="wallettemplate">

    <!-- Quyền bắt buộc để sync Bitcoin MAINNET -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="WalletTemplate MAINNET"
        android:name="androidx.multidex.MultiDexApplication"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar"
        tools:targetApi="31">

        <!-- Activity chính -->
        <activity
            android:name=".Main"
            android:exported="true"
            android:label="WalletTemplate MAINNET">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Các màn còn lại mày đã convert -->
        <activity android:name=".SendMoneyController" />
        <activity android:name=".WalletSettingsController" />
        <activity android:name=".WalletPasswordController" />
        <activity android:name=".WalletSetPasswordController" />
        <activity android:name=".MainController" />

    </application>
</manifest>