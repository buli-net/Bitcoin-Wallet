<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="600dp"
        android:layout_height="400dp"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:gravity="center_vertical"
            android:background="#EEEEEE"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="password"
                android:textSize="30sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/explanationLabel"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_margin="22dp"
            android:text="Setting a password on your wallet makes it safer against viruses and theft. You will need to enter your password whenever money is sent." />

        <ProgressBar
            android:id="@+id/progressMeter"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="87dp"
            android:layout_height="114dp"
            android:layout_gravity="center"
            android:alpha="0" />

        <GridLayout
            android:id="@+id/widgetGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="3"
            android:layout_marginStart="22dp"
            android:layout_marginEnd="17dp">

            <TextView
                android:layout_width="120dp"
                android:text="Enter password" />

            <EditText
                android:id="@+id/pass1"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:inputType="textPassword" />

            <TextView
                android:layout_width="120dp"
                android:text="Repeat password" />

            <EditText
                android:id="@+id/pass2"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:inputType="textPassword" />

            <Space
                android:layout_width="120dp" />

            <Button
                android:id="@+id/setPasswordBtn"
                android:layout_width="wrap_content"
                android:layout_gravity="end"
                android:text="Set password" />
        </GridLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:padding="14dp">

            <Button
                android:id="@+id/closeButton"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Close" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>