<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:padding="16dp">
    <TextView android:id="@+id/balanceLabel" android:text="Balance"
        android:textSize="18sp" android:layout_width="wrap_content" android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
    <TextView android:id="@+id/balance" android:text="0.00 BTC"
        android:textSize="32sp" android:textStyle="bold"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/balanceLabel" app:layout_constraintStart_toStartOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/addressCard"
        android:layout_width="0dp" android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/balance" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" app:cardCornerRadius="16dp">
        <LinearLayout android:orientation="vertical" android:gravity="center"
            android:padding="16dp" android:layout_width="match_parent" android:layout_height="wrap_content">
            <ImageView android:id="@+id/qrCode" android:layout_width="200dp" android:layout_height="200dp"/>
            <TextView android:id="@+id/address" android:text="address will appear here"
                android:textIsSelectable="true" android:layout_marginTop="12dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Tap to copy" android:textSize="12sp" android:alpha="0.6"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView android:id="@+id/syncStatus" android:text="Synchronising with the Bitcoin network..."
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/controlsBox"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout android:id="@+id/controlsBox" android:orientation="horizontal"
        android:layout_width="0dp" android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <com.google.android.material.button.MaterialButton android:id="@+id/sendMoneyBtn"
            android:text="Send Money" style="@style/Widget.Material3.Button"
            android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/settingsBtn"
            android:text="Settings" style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_weight="1" android:layout_marginStart="12dp"
            android:layout_width="0dp" android:layout_height="wrap_content"/>
    </LinearLayout>

    <ProgressBar android:id="@+id/syncProgress" style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp" android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/syncStatus"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
